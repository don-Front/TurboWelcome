# .cursorrules — TurboWelcome Project Constitution

# ===========================
# 1. Общая информация о проекте
# ===========================
project:
  name: TurboWelcome
  description: >
    Платформа для адаптации новых сотрудников. Два типа пользователей:
    - HR / Руководитель: создаёт и управляет программой онбординга, отслеживает прогресс.
    - Новый сотрудник: проходит адаптацию, знакомится с компанией, сотрудниками, процессами.
  repository: монорепозиторий
  branching:
    main: базовая ветка с бекендом и общей документацией
    Web: разработка веб-клиента (React)
    Mobile: разработка мобильного клиента (Kotlin)

# ===========================
# 2. Технологический стек
# ===========================
stack:
  backend:
    runtime: Python 3.11+
    framework: Django 5.0+
    api: Django REST Framework
    db: PostgreSQL (для продакшена), SQLite (для разработки)
  frontend:
    framework: React 18 (Create React App)
    state: React Context + hooks
    http: axios
  mobile:
    language: Kotlin
    platform: Android (Jetpack Compose)

# ===========================
# 3. Структура проекта (обязательно сохранять)
# ===========================
structure:
  root:
    - .cursorrules
    - README.md
    - Back/
        - manage.py
        - requirements.txt
        - turbowelcome/          # настройки проекта Django
            - settings/
                - base.py
                - development.py
                - production.py
            - urls.py
            - wsgi.py
        - apps/                  # бизнес-приложения
            - users/             # модель User, роли, регистрация, аутентификация
            - company/           # структура компании, департаменты, профили сотрудников
            - onboarding/        # программы адаптации, шаги, материалы, отслеживание прогресса
            - api/               # базовые классы API, миксины, утилиты
    - Front/
        - src/
            - components/        # переиспользуемые UI-компоненты (кнопки, карточки, модалки)
            - features/          # модули с бизнес-логикой (Onboarding, Company, Auth)
            - pages/             # страницы приложения (HRDashboard, EmployeeOnboarding, Profile)
            - services/          # API-клиент (инстанс axios, эндпоинты)
            - hooks/             # кастомные хуки (useAuth, useOnboarding)
            - context/           # React Context провайдеры (AuthContext)
            - App.js
    - Mobile/ (ветка Mobile)
        - ... (структура Android-проекта)

# ===========================
# 4. Принципы разработки (DRY, SOLID, модульность)
# ===========================
principles:
  - DRY: >
      Избегать дублирования кода. Выносить повторяющуюся логику в переиспользуемые модули:
      в Django — абстрактные модели/миксины, на фронтенде — общие компоненты и хуки.
  - SOLID:
      - S: Каждый класс/модуль/компонент решает одну задачу.
      - O: Код открыт для расширения (новые роли, шаги адаптации), закрыт для модификации ядра.
      - L: Правильная иерархия наследования в сериализаторах и вьюхах.
      - I: Интерфейсы (API) клиентов не должны зависеть от неиспользуемых методов.
      - D: Зависимости строить от абстракций (сервисный слой перед API на фронте).
  - Модульность: >
      Django приложения слабо связаны, общаются через четко определённые интерфейсы (сериализаторы).
      React разбит на фичи — каждая фича независима, экспортирует публичное API.

# ===========================
# 5. Поведение AI-агента (Cursor)
# ===========================
ai_behavior:
  general:
    - Всегда учитывай текущий контекст: структуру проекта, существующий код и стиль оформления.
    - Действуй максимально автономно, минимизируй уточняющие вопросы к разработчику.
  simple_tasks:
    description: >
      Задачи типа "создать кнопку", "добавить функцию", "обновить стиль".
      Не спрашивай разрешения, сразу предлагай реализацию, соблюдая стиль проекта.
      Используй понятные имена переменных, компонентов, функций.
  complex_tasks:
    description: >
      Задачи типа "реализовать онбординг-дашборд для HR", "добавить загрузку аватаров".
      Разбей задачу на подзадачи в комментарии, затем последовательно реализуй каждую.
      При необходимости используй виртуальных агентов: планировщик, разработчик, ревьюер.
      После реализации проверяй соответствие кода принципам DRY/SOLID.
  code_generation:
    - Для Django: всегда создавай миграции, если меняешь модель.
    - Для React: предпочитай функциональные компоненты и хуки.
    - Используй типизацию (Python type hints, PropTypes или TypeScript, если внедрён).
    - Пиши комментарии к сложной бизнес-логике на русском или английском — по контексту.
  problem_solving:
    - Если встречаешь ошибку, проанализируй логи (если доступны) и предложи исправление.
    - В случае неоднозначности выбора (библиотека, подход) — предпочитай более простое и стандартное решение.

# ===========================
# 6. Роли пользователей и ключевые сущности
# ===========================
roles:
  HR_Manager:
    actions:
      - управление профилями сотрудников
      - создание/редактирование программы онбординга
      - просмотр прогресса новых сотрудников
      - доступ к админ-панели Django (по необходимости)
  Employee:
    actions:
      - просмотр плана адаптации
      - прохождение шагов (ознакомительные материалы, задания)
      - знакомство с коллегами и структурой компании
      - редактирование собственного профиля

entities:
  User: кастомная модель с ролью (HR, Employee), email, именем, аватаром
  Company: основная информация, отделы (Department), должности
  OnboardingProgram: шаблон программы, состоящий из OnboardingStep (шагов)
  EmployeeProgress: связь сотрудник-шаг, статус выполнения, заметки

# ===========================
# 7. API-дизайн (общие правила)
# ===========================
api:
  prefix: /api/v1/
  auth: JWT (djangorestframework-simplejwt)
  pagination: PageNumberPagination, 20 объектов на странице
  serialization: Использовать ModelSerializer, вложенные сериализаторы для связанных объектов только при необходимости
  permissions: Кастомные классы разрешений (IsHR, IsOwnerOrHR)
  documentation: Автогенерация схемы (drf-spectacular) по мере разработки

# ===========================
# 8. Стиль кода и конвенции
# ===========================
code_style:
  python:
    follow: PEP 8
    naming: snake_case для переменных/функций, PascalCase для классов
    imports: сначала стандартные, потом сторонние, затем локальные
  javascript/react:
    naming: camelCase для переменных/функций, PascalCase для компонентов
    files: один компонент — один файл, папка компонента может содержать index.js, styles.module.css
    state: useReducer для сложного состояния, Context для глобального
  git:
    commit_messages: осмысленные, на русском или английском, формат: "feat: добавлен дашборд сотрудника"
    branches: задачи в отдельных feature-ветках, затем PR в Web или Mobile